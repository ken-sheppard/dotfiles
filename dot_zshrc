# Dotfiles management
alias dotfiles="chezmoi cd"
alias dots-update="chezmoi update"
alias dots-edit="chezmoi edit"
alias dots-diff="chezmoi diff"
alias dots-push="~/.local/bin/update-dotfiles.sh"

# Homebrew shortcuts
alias brewup="brew update && brew upgrade && brew cleanup"
alias brewdump="brew bundle dump --force --describe --file=$HOME/Brewfile && chezmoi re-add"

